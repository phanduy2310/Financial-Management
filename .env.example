# ==============================================
# Environment Variables Template
# Copy this file to .env and fill in the values
# ==============================================
PORT=8081
MYSQL_HOST=mysql
MYSQL_USER=finance_user
MYSQL_PASSWORD=finance_pass
MYSQL_DATABASE=financial_auth
JWT_SECRET=local_dev_jwt_secret
JWT_REFRESH_SECRET=local_dev_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
NOTIFICATION_SERVICE_URL=http://notification-service:8084/api
FRONTEND_URL=http://localhost:5000
INTERNAL_API_KEY=internal_secret_key_dev
# --- General ---
COMPOSE_PROJECT_NAME=microservices-assignment
ENVIRONMENT=development

# --- Database (adjust to your chosen DB) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mydb
DB_USER=admin
DB_PASSWORD=changeme

# --- Service Ports ---
SERVICE_A_PORT=5001
SERVICE_B_PORT=5002
GATEWAY_PORT=8080
FRONTEND_PORT=3000

# --- API Gateway ---
GATEWAY_SECRET=your-gateway-secret

# --- Add more variables as needed for your stack ---
# REDIS_URL=redis://localhost:6379
# RABBITMQ_URL=amqp://localhost:5672
# JWT_SECRET=your-jwt-secret
